ELEVENLABS_API_KEY=
GEMINI_API_KEY=

# Local web settings. Render values are defined in render.yaml.
DUBSYNC_DATA_DIR=runtime-data
DUBSYNC_PROVIDERS_PATH=provider.yaml
DUBSYNC_STYLE_PATH=style_profile.yaml
DUBSYNC_STATIC_DIR=web/dist
DUBSYNC_RETENTION_HOURS=24
DUBSYNC_MAX_UPLOAD_BYTES=2147483648
DUBSYNC_MAX_JOBS_PER_HOUR=5
DUBSYNC_WORKER_THREADS=1
DUBSYNC_CLEANUP_INTERVAL_SECONDS=300
DUBSYNC_PROCESSING_INLINE=0
DUBSYNC_ENABLE_DOCS=0
